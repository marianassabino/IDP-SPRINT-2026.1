APP_NAME=Normalizador JusBrasil
APP_ENV=development
APP_VERSION=0.1.0

# JWT
JWT_SECRET_KEY=<gere com: python3 -c "import secrets; print(secrets.token_urlsafe(64))">
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<senha-do-banco>
POSTGRES_DB=normalizador
DATABASE_URL=postgresql+asyncpg://postgres:<senha-do-banco>@db:5432/normalizador

# AWS S3
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_S3_BUCKET_NAME=<nome-do-bucket>
AWS_S3_REGION=us-east-1
# AWS_S3_ENDPOINT_URL=http://localhost:4566
